{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2021"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "jest"],
    "baseUrl": ".",
    "paths": {
      "@travel-plan/shared": ["shared/src/index.ts"],
      "@travel-plan/mcp": ["mcp/src/lib.ts"]
    }
  },
  "include": [
    "server/**/*.ts",
    "mcp/src/**/*.ts",
    "mcp/tests/**/*.ts",
    "shared/src/**/*.ts",
    "migrations/**/*.ts"
  ],
  "exclude": ["**/node_modules/**", "**/dist/**"]
}

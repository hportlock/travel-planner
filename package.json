{
  "name": "travel-plan",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant travel-planning web app (host + read-only share links, theming, MCP, PWA).",
  "workspaces": [
    "shared",
    "server",
    "mcp",
    "client"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:shared && npm run build:mcp && npm run build:server && npm run build:client && npm run build:migrate",
    "build:shared": "npm run build --workspace @travel-plan/shared",
    "build:mcp": "npm run build --workspace @travel-plan/mcp",
    "build:server": "npm run build --workspace @travel-plan/server",
    "build:client": "npm run build --workspace @travel-plan/client",
    "build:migrate": "tsc -p tsconfig.migrate.json",
    "dev": "npm run build:shared && npm run build:mcp && concurrently -k -n server,client -c blue,magenta \"npm run dev --workspace @travel-plan/server\" \"npm run dev --workspace @travel-plan/client\"",
    "dev:server": "npm run build:shared && npm run build:mcp && npm run dev --workspace @travel-plan/server",
    "migrate:latest": "knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.ts migrate:rollback",
    "migrate:prod": "knex --knexfile dist-migrate/knexfile.js migrate:latest --env production",
    "seed:run": "knex --knexfile knexfile.ts seed:run",
    "db:reset": "rimraf dev.sqlite3 && npm run migrate:latest && npm run seed:run",
    "test": "jest --runInBand",
    "mcp": "npm run start --workspace @travel-plan/mcp",
    "typecheck": "tsc -b shared server mcp --pretty"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "knex": "^3.1.0",
    "playwright-core": "^1.47.0",
    "rimraf": "^5.0.7",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "pg": "^8.12.0"
  }
}

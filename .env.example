# ---- Server ----
NODE_ENV=development
PORT=3001
# Public base URL of the app (used for OAuth redirect + share-link generation)
APP_BASE_URL=http://localhost:5173

# Secret used to sign the JWT session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=dev-only-insecure-session-secret-change-me

# Google OAuth client id (the audience the server validates ID tokens against)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ---- Database ----
# In production (Dokku) the postgres plugin injects DATABASE_URL automatically.
# Leave unset in dev/test to use SQLite (dev.sqlite3 / :memory:).
# DATABASE_URL=postgres://user:pass@host:5432/travel_plan

# ---- MCP: local stdio server (mcp/) ----
# Where the stdio MCP REST client points, and the PAT it authenticates with.
TRAVEL_API_URL=http://localhost:3001
TRAVEL_PAT=tp_pat_xxx

# ---- MCP: remote HTTP endpoint (served by the Express app at /mcp) ----
# Secret for signing OAuth access-token JWTs. Falls back to SESSION_SECRET if
# unset. Generate with: openssl rand -hex 32
# MCP_TOKEN_SECRET=
# Public base URL where /authorize + /token are reachable (the OAuth issuer).
# In prod the SPA and API are same-origin, so APP_BASE_URL is used automatically.
# In dev the API (3001) and SPA (5173) differ — set this to the API origin to
# test the remote endpoint locally (e.g. with the MCP inspector):
# MCP_PUBLIC_URL=http://localhost:3001
